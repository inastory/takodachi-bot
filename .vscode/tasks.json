{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "PyInstaller: 從原始碼全新生成打包 (不使用 Spec)",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "pyinstaller",
                "src/takodachi_bot/takodachi.py",
                "--onefile",
                "--noconsole",
                "--hidden-import", "comtypes",
                "--hidden-import", "pycaw",
                "--hidden-import", "pystray._win32"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "PyInstaller: 依據 Spec 快速打包 (推薦日常使用)",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "pyinstaller",
                "takodachi.spec"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}