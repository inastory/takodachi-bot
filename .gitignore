# ==========================================
# 1. Python Byte-compiled files
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 2. PyInstaller build cache and distributions
# ==========================================
build/
dist/
# Note: DO NOT ignore *.spec here, because we need to track takodachi.spec

# ==========================================
# 3. Project Metadata / Distribution Info
# ==========================================
# Generated by Python packaging tools (e.g., uv, setuptools)
*.egg-info/

# ==========================================
# 4. Runtime Logs
# ==========================================
# Ignore everything inside logs
logs/

# ==========================================
# 5. uv and Virtual Environments
# ==========================================
.venv/
.uv/

# ==========================================
# 6. Sensitive data / Environment variables
# ==========================================
# Contains your Discord Bot Token, NEVER commit this!
.env

# ==========================================
# 7. IDEs and Editors
# ==========================================
.idea/
.vscode/settings.json